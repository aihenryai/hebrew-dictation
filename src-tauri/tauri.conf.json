{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "הכתבה בעברית",
  "version": "2.5.0",
  "identifier": "com.bintech.hebrew-dictation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "הכתבה בעברית",
        "width": 300,
        "height": 260,
        "minWidth": 240,
        "minHeight": 200,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": true
      },
      {
        "label": "toolbar",
        "title": "Dictation Toolbar",
        "url": "index.html?window=toolbar",
        "width": 360,
        "height": 56,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "הכתבה בעברית — BinTech AI"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "BinTech AI",
    "shortDescription": "הכתבה בעברית — Hebrew voice dictation for Windows",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": ["Hebrew"],
        "customLanguageFiles": {
          "Hebrew": "nsis/Hebrew.nsh"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1QjlENDhFRjIyRUM4NDUKUldSRnlDN3lqdFM1ZFF0ZmJ5TDBQWW44OU5qWGQ0ZUFRWm90WGQ3ZDhVR1BPOVB2R1kxdHNENjUK",
      "endpoints": [
        "https://github.com/aihenryai/hebrew-dictation/releases/latest/download/latest.json"
      ]
    }
  }
}
