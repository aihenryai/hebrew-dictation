<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Applied at signing. Under the hardened runtime (Tauri's default on
	     macOS), the microphone is blocked unless this entitlement is present —
	     required in addition to NSMicrophoneUsageDescription in Info.plist. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
